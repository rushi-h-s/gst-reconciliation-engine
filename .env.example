# ── Supabase (cloud) ────────────────────────────────────────────────────────
# Used by: FastAPI REST client + Supabase Storage
SUPABASE_URL=https://bcbpzzmvcxqgebhrhsjr.supabase.co
SUPABASE_SERVICE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImJjYnB6em12Y3hxZ2ViaHJoc2pyIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzk2OTkyNTEsImV4cCI6MjA5NTI3NTI1MX0.unknhTXYmRpimuQiKryODs4NnLj8IF2wr7tCNS_tzQk"
"
# Direct Postgres DSN for pgmq (asyncpg).
# In docker-compose this is overridden to point at the local pgmq_db container.
# For cloud-only runs, point this at your Supabase Postgres:
#   postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres
SUPABASE_DB_URL=postgresql://postgres.bcbpzzmvcxqgebhrhsjr:[YOUR-PASSWORD]@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres

# ── Ollama (external) ────────────────────────────────────────────────────────
# IMPORTANT: default model in code is qwen2.5vl:7b — change to match what you
# have actually pulled in Ollama.  Do NOT use qwen3.5:cloud as the model name;
# pull the correct tag with: ollama pull qwen2.5vl:7b
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5vl:7b

# ── Queue ────────────────────────────────────────────────────────────────────
QUEUE_NAME=invoice_extraction
WORKER_POLL_INTERVAL_SECONDS=2.0
WORKER_VISIBILITY_TIMEOUT_SECONDS=120

# ── JWT auth ─────────────────────────────────────────────────────────────────
# HS256 secret: Supabase → Project Settings → API → JWT Secret
JWT_SECRET=your-supabase-jwt-secret

# ── Frontend (Vite) ──────────────────────────────────────────────────────────
# VITE_ORG_ID is display-only; auth now uses VITE_JWT_TOKEN.
# Get a user token: sign in via Supabase Auth and copy the access_token.
VITE_ORG_ID=00000000-0000-0000-0000-000000000000
VITE_JWT_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
